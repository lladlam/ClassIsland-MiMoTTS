<ci:SpeechProviderControlBase x:Class="MiMoTTS.Controls.SpeechProviderSettingsControls.MiMoSpeechServiceSettingsControl"
                              xmlns="https://github.com/avaloniaui"
                              xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                              xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                              xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                              xmlns:local="clr-namespace:MiMoTTS.Controls.SpeechProviderSettingsControls"
                              xmlns:ci="http://classisland.tech/schemas/xaml/core"
                              xmlns:controls="clr-namespace:FluentAvalonia.UI.Controls;assembly=FluentAvalonia"
                              mc:Ignorable="d"
                              d:DesignHeight="450"
                              d:DesignWidth="800">
    <StackPanel DataContext="{Binding}" Spacing="1">
        <controls:SettingsExpanderItem Content="API 地址" Description="已内嵌为官方地址，不再允许手动修改。">
            <controls:SettingsExpanderItem.Footer>
                <TextBlock Width="280" VerticalAlignment="Center" Text="{Binding FixedApiBaseUrl}"/>
            </controls:SettingsExpanderItem.Footer>
        </controls:SettingsExpanderItem>

        <controls:SettingsExpanderItem Content="API Key">
            <controls:SettingsExpanderItem.Footer>
                <TextBox Width="280"
                         PasswordChar="*"
                         Text="{Binding Settings.ApiKey, Mode=TwoWay}"
                         TextChanged="PasswordChangedHandler"/>
            </controls:SettingsExpanderItem.Footer>
        </controls:SettingsExpanderItem>

        <controls:SettingsExpanderItem Content="模型" Description="目前仅支持 mimo-v2-tts 与 mimo-v2.5-tts">
            <controls:SettingsExpanderItem.Footer>
                <ComboBox Width="180"
                          ItemsSource="{Binding ModelOptions}"
                          SelectedItem="{Binding Settings.Model, Mode=TwoWay}"/>
            </controls:SettingsExpanderItem.Footer>
        </controls:SettingsExpanderItem>

        <controls:SettingsExpanderItem Content="音色" Description="例如：mimo_default / default_zh / default_en">
            <controls:SettingsExpanderItem.Footer>
                <TextBox Width="180" Text="{Binding Settings.Voice, Mode=TwoWay}"/>
            </controls:SettingsExpanderItem.Footer>
        </controls:SettingsExpanderItem>

        <controls:SettingsExpanderItem Content="音频格式">
            <controls:SettingsExpanderItem.Footer>
                <TextBox Width="120" Text="{Binding Settings.AudioFormat, Mode=TwoWay}"/>
            </controls:SettingsExpanderItem.Footer>
        </controls:SettingsExpanderItem>

        <controls:SettingsExpanderItem Content="风格标签" Description="v2 会注入 &lt;style&gt;，v2.5 会转换为开头的括号风格标签。">
            <controls:SettingsExpanderItem.Footer>
                <TextBox Width="220" Text="{Binding Settings.Style, Mode=TwoWay}"/>
            </controls:SettingsExpanderItem.Footer>
        </controls:SettingsExpanderItem>

        <controls:SettingsExpanderItem Content="语速" Description="会和风格标签一起参与文本前缀生成。">
            <controls:SettingsExpanderItem.Footer>
                <ComboBox Width="150"
                          ItemsSource="{Binding SpeedStyleOptions}"
                          SelectedItem="{Binding Settings.SpeedStyle, Mode=TwoWay}"/>
            </controls:SettingsExpanderItem.Footer>
        </controls:SettingsExpanderItem>

        <controls:SettingsExpanderItem IsVisible="{Binding IsV25Model}"
                                       Content="唱歌模式"
                                       Description="仅 mimo-v2.5-tts 支持，会在文本最前面自动添加 (唱歌) 标签。">
            <controls:SettingsExpanderItem.Footer>
                <CheckBox IsChecked="{Binding Settings.EnableSingingMode, Mode=TwoWay}"/>
            </controls:SettingsExpanderItem.Footer>
        </controls:SettingsExpanderItem>

        <controls:SettingsExpanderItem IsVisible="{Binding IsV25Model}"
                                       Content="启用自然语言控制"
                                       Description="仅 mimo-v2.5-tts 支持，会把提示词作为 user 角色消息发送。">
            <controls:SettingsExpanderItem.Footer>
                <CheckBox IsChecked="{Binding Settings.EnableUserPrompt, Mode=TwoWay}"/>
            </controls:SettingsExpanderItem.Footer>
        </controls:SettingsExpanderItem>

        <controls:SettingsExpanderItem IsVisible="{Binding IsV25Model}"
                                       Content="自然语言控制提示词"
                                       Description="用于控制语气、情绪、节奏等；不会直接出现在合成语音中。">
            <controls:SettingsExpanderItem.Footer>
                <TextBox Width="360"
                         Height="72"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         Text="{Binding Settings.UserPrompt, Mode=TwoWay}"/>
            </controls:SettingsExpanderItem.Footer>
        </controls:SettingsExpanderItem>
    </StackPanel>
</ci:SpeechProviderControlBase>
